# Modelo das variaveis de ambiente da API (VERSIONADO - sem segredos).
# Copie para .env e preencha com os valores reais do seu ambiente:
#   cp .env.example .env
# Em producao (VPS), defina estas variaveis no ambiente do processo.

# Porta da API
PORT=8080

# Chave do header x-api-key (a mesma digitada no gate do frontend)
API_KEY=

# Origens adicionais autorizadas a chamar a API (separadas por virgula).
# Localhost, gestagua.vercel.app e gestagua.arvo.tec.br já são permitidos
# diretamente pela configuração da aplicação.
ALLOWED_ORIGINS=

# Postgres em producao (Railway): use a URL privada do servico Postgres.
# Na Railway, defina DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=

# Postgres local/VPS (fallback quando DATABASE_URL estiver vazia)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=

# Caminhos de arquivos (opcionais). Sem estas variaveis, a API usa
# banco_ativo.txt, api.log e sync-state.json na propria pasta. Na VPS, onde
# esses arquivos ficam fora do app, aponte com caminhos ABSOLUTOS:
# POINTER_FILE=C:\arvo-sync\banco_ativo.txt
# LOG_FILE=C:\arvo-sync\logs\api.log
# SYNC_STATE_FILE=C:\arvo-sync\sync-state.json

# ---------------------------------------------------------------------------
# Sincronizacao Azure -> Railway: estas NAO vao no .env da API. Sao variaveis
# de ambiente da VPS (setx /M), lidas por scripts/sync-worker.ps1:
#   GESTAGUA_API_URL      URL publica desta API (com https://)
#   GESTAGUA_API_KEY      a mesma API_KEY acima
#   GESTAGUA_AZURE_URL    connection string do Postgres do Azure (origem)
#   GESTAGUA_TARGET_URL   connection string publica do Postgres da Railway
# ---------------------------------------------------------------------------
